---
import Layout from "../components/Layout.astro";
import ToolCard from "../components/ToolCard.astro";
import ToolDiscovery from "../components/ToolDiscovery";
import CategoryIcon from "../components/CategoryIcon.astro";
import { categories } from "../lib/categories";
import { tools } from "../lib/tools";
import { breadcrumbSchema, site } from "../lib/seo";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.origin,
    description: site.description,
    publisher: {
      "@type": "Organization",
      name: "VIOX",
      url: "https://viox.com/",
      logo: site.logo
    }
  },
  breadcrumbSchema([{ name: "Electrical Tools", url: site.origin }])
];
const searchableTools = tools.map(({ slug, title, shortTitle, description, keywords }) => ({ slug, title, shortTitle, description, keywords }));
---

<Layout title="Free Electrical Calculators for Low-Voltage Design | VIOX" description={site.description} canonical={`${site.origin}/`} schema={schema}>
  <main>
    <section class="hero-shell">
      <div class="hero-copy">
        <div class="eyebrow">VIOX engineering tools</div>
        <h1>Low-voltage calculation tools for practical product selection.</h1>
        <p>Support panel builders, OEMs, distributors, and electrical engineers with quick reference checks for surge protection, circuit protection, cable sizing, motor control, and EV charging loads.</p>
        <div class="hero-actions">
          <a class="button primary" href="#tools">Browse tools</a>
          <a class="button secondary" href="https://viox.com/">Visit VIOX.com</a>
        </div>
      </div>
      <div class="hero-workbench" aria-label="Four-step circuit sizing workflow">
        <div class="workbench-header">
          <span>Guided workflow</span>
          <strong>Size a circuit in four steps</strong>
          <p>Move from connected load to a checked conductor.</p>
        </div>
        <ol class="workflow-list">
          <li><a href="/kw-kva-amp-calculator/"><span class="workflow-number">01</span><span class="workflow-copy"><strong>Calculate Load Current</strong><small>Power → operating current</small></span><b>Ib</b><i aria-hidden="true">→</i></a></li>
          <li><a href="/circuit-breaker-size-calculator/"><span class="workflow-number">02</span><span class="workflow-copy"><strong>Select Breaker Rating</strong><small>Current → MCB or MCCB</small></span><b>In</b><i aria-hidden="true">→</i></a></li>
          <li><a href="/cable-size-calculator/"><span class="workflow-number">03</span><span class="workflow-copy"><strong>Size the Conductor</strong><small>Current + installation</small></span><b>Iz</b><i aria-hidden="true">→</i></a></li>
          <li><a href="/voltage-drop-calculator/"><span class="workflow-number">04</span><span class="workflow-copy"><strong>Check Voltage Drop</strong><small>Cable + route length</small></span><b>Vd%</b><i aria-hidden="true">→</i></a></li>
        </ol>
        <div class="workflow-rule"><span>Protection relationship</span><strong>Ib ≤ In ≤ Iz</strong><i aria-hidden="true">→</i><b>Check Vd%</b></div>
      </div>
    </section>

    <ToolDiscovery tools={searchableTools} client:load />

    <section class="section-shell" id="tools">
      <div class="tool-grid">
        {tools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>

    <section class="section-shell">
      <div class="section-heading compact">
        <span class="eyebrow">Browse by task</span>
        <h2>Choose an electrical calculator category.</h2>
      </div>
      <div class="category-grid">
        {Object.values(categories).map((category) => (
          <a class="category-card" href={`/category/${category.slug}/`}>
            <span class="category-card-icon"><CategoryIcon category={category.slug} size={27} /></span>
            <h3>{category.title}</h3>
            <p>{category.deck}</p>
            <i aria-hidden="true">→</i>
          </a>
        ))}
      </div>
    </section>

    <section class="cta-strip">
      <div>
        <span class="eyebrow">Factory selection support</span>
        <h2>Need a product recommendation after the calculation?</h2>
        <p>Send the result to VIOX for SPD, MCB, MCCB, RCBO, contactor, cable gland, busbar, and EV charging protection support.</p>
      </div>
      <a class="cta-button" href="https://viox.com/contact">Contact</a>
    </section>
  </main>
</Layout>
