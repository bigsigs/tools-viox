---
import { categories } from "../lib/categories";
import type { ToolDefinition } from "../lib/types";

type Props = {
  tool: ToolDefinition;
};

const { tool } = Astro.props;
const category = categories[tool.category];
const icons: Record<string, string> = {
  "spd-calculator": "SPD",
  "voltage-drop-calculator": "Vd",
  "cable-size-calculator": "mm²",
  "conduit-fill-calculator": "%",
  "dc-voltage-drop-calculator": "DC",
  "awg-wire-size-calculator": "AWG",
  "mm2-to-awg-converter": "↔",
  "circuit-breaker-size-calculator": "A",
  "transformer-sizing-calculator": "kVA",
  "short-circuit-current-calculator": "kA",
  "kw-kva-amp-calculator": "kW",
  "three-phase-current-calculator": "3P",
  "motor-current-calculator": "M",
  "ev-charger-load-calculator": "EV",
  "cable-gland-size-calculator": "M",
  "busbar-current-rating-calculator": "Cu"
  ,"fuse-sizing-calculator": "F"
  ,"power-factor-correction-calculator": "PF"
  ,"motor-starter-selection-calculator": "YΔ"
  ,"three-phase-voltage-unbalance-calculator": "3V"
  ,"pv-combiner-box-sizing-calculator": "PV"
  ,"advanced-spd-selection-calculator": "Up"
  ,"mcb-inrush-compatibility-checker": "C"
  ,"rcd-rcbo-selector": "ΔI"
  ,"ats-selection-calculator": "ATS"
  ,"cable-lug-selector": "LUG"
  ,"battery-c-rate-runtime-calculator": "C"
  ,"energy-cost-calculator": "kWh"
  ,"terminal-heating-calculator": "I²R"
  ,"busbar-short-circuit-force-calculator": "F"
  ,"ohms-law-calculator": "Ω"
  ,"watts-amps-volts-calculator": "W/A"
  ,"ev-charging-time-cost-calculator": "EV"
  ,"battery-charging-time-calculator": "h"
  ,"resistor-series-parallel-calculator": "R"
  ,"electrical-unit-converter": "↔"
  ,"contactor-selection-calculator": "AC3"
  ,"breaker-selectivity-calculator": "Σ"
  ,"lightning-risk-assessment-calculator": "LPS"
  ,"enclosure-temperature-rise-calculator": "ΔT"
  ,"panel-heat-loss-calculator": "ΣW"
  ,"pv-string-sizing-calculator": "PV"
  ,"off-grid-solar-system-calculator": "PV+"
  ,"spd-backup-fuse-calculator": "SPD/F"
  ,"earth-fault-loop-impedance-calculator": "Zs"
  ,"cable-derating-factor-calculator": "K"
  ,"maximum-demand-calculator": "MD"
  ,"protective-conductor-size-calculator": "PE"
  ,"cable-short-circuit-thermal-calculator": "I²t"
  ,"motor-starting-voltage-drop-calculator": "ΔV"
};
---

<article class="tool-card">
  <div class="tool-card-top">
    <span class="tool-icon" aria-hidden="true">{icons[tool.slug] ?? "V"}</span>
    <span class="tool-tag">{category.deck}</span>
  </div>
  <h3><a href={`/${tool.slug}/`}>{tool.title}</a></h3>
  <p>{tool.description}</p>
  <a class="card-link" href={`/${tool.slug}/`}>Open calculator</a>
</article>
