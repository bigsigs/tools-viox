---
import "../styles/global.css";
import { site } from "../lib/seo";
import { categories } from "../lib/categories";
import CategoryIcon from "./CategoryIcon.astro";

type Props = {
  title: string;
  description: string;
  canonical?: string;
  schema?: unknown[];
};

const { title, description, canonical = site.origin, schema = [] } = Astro.props;
const categoryNav = [
  { slug: "electrical-fundamentals", label: "Fundamentals" },
  { slug: "power-distribution", label: "Power Distribution" },
  { slug: "panels-enclosures", label: "Panels & Enclosures" },
  { slug: "cable-wire", label: "Cable & Voltage Drop" },
  { slug: "cable-management", label: "Cable Management" },
  { slug: "circuit-protection", label: "Circuit Protection" },
  { slug: "motor-control", label: "Motors & Drives" },
  { slug: "solar-storage", label: "Solar & Battery" },
  { slug: "surge-protection", label: "Surge & Lightning" },
  { slug: "ev-charging", label: "EV Charging" },
  { slug: "lighting-design", label: "Lighting Design" }
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="https://viox.com/wp-content/uploads/2024/01/cropped-icon-32x32.png" sizes="32x32" />
    <link rel="icon" href="https://viox.com/wp-content/uploads/2024/01/cropped-icon-192x192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="https://viox.com/wp-content/uploads/2024/01/cropped-icon-180x180.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={site.logo} />
    <meta property="og:image:alt" content="VIOX Electric" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content={site.logo} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    {schema.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="VIOX Electrical Tools home">
        <span class="brand-logo-wrap">
          <img class="brand-logo" src={site.logo} alt="VIOX" width="140" height="42" loading="eager" decoding="async" />
        </span>
      </a>
      <nav class="main-nav desktop-nav" aria-label="Main navigation">
        <a href="/#tools">All Tools</a>
        <div class="category-menu">
          <button type="button" aria-haspopup="true">Calculators</button>
          <div class="category-menu-panel">
            <div class="category-menu-heading">
              <strong>Electrical calculators</strong>
              <span>Browse by engineering task</span>
            </div>
            <div class="category-menu-grid">
              {categoryNav.map((item) => (
                <a href={`/category/${item.slug}/`}>
                  <i><CategoryIcon category={item.slug} size={19} /></i>
                  <span><strong>{item.label}</strong><small>{categories[item.slug].deck}</small></span>
                </a>
              ))}
              <a class="view-all-category" href="/#tools"><i aria-hidden="true">→</i><span><strong>View All Tools</strong><small>Search all 62 calculators</small></span></a>
            </div>
          </div>
        </div>
        <a href="https://viox.com/products/">Products</a>
        <a href="https://viox.com/contact">Contact</a>
      </nav>
      <div class="mobile-header-actions">
        <a class="header-icon header-search" href="/#calculator-search" aria-label="Search calculators" title="Search calculators"></a>
        <details class="mobile-menu">
          <summary class="header-icon header-menu" aria-label="Open navigation" title="Menu"><span></span></summary>
          <nav aria-label="Mobile navigation">
            <a class="mobile-all-tools" href="/#tools">All Tools</a>
            {categoryNav.map((item) => <a href={`/category/${item.slug}/`}><i><CategoryIcon category={item.slug} size={19} /></i><span>{item.label}</span></a>)}
            <a href="https://viox.com/products/"><i aria-hidden="true">V</i><span>VIOX Products</span></a>
            <a href="https://viox.com/contact"><i aria-hidden="true">@</i><span>Contact</span></a>
          </nav>
        </details>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="footer-simple">
        <a class="footer-brand" href="/" aria-label="VIOX Electrical Tools home">
          <img src={site.logo} alt="VIOX" width="132" height="40" loading="lazy" decoding="async" />
          <span>Electrical Tools</span>
        </a>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/#tools">Tools</a>
          <a href="/category/circuit-protection/">Protection</a>
          <a href="/category/cable-wire/">Cable</a>
          <a href="https://viox.com/">VIOX.com</a>
          <a href="https://viox.com/contact">Contact</a>
        </nav>
        <p class="footer-contact">
          <a href="mailto:sales@viox.com">sales@viox.com</a>
          <span>+8618066396588</span>
        </p>
      </div>
      <div class="footer-note">
        <p>© 2026 VIOX Electric.</p>
        <p>Calculator results are for preliminary selection only. Final design must follow local codes, standards, and qualified engineering review.</p>
        <nav aria-label="Footer legal links">
          <a href="https://viox.com/terms-use/">Terms Use</a>
          <a href="https://viox.com/privacy-policy/">Privacy</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
